# Supabase Configuration
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api

# Required: Your Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Required: Your Supabase anon/public key
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Required: Supabase Edge Functions URL
# Production: https://your-project.supabase.co/functions/v1
# Local: http://127.0.0.1:54321/functions/v1
VITE_SUPABASE_FUNCTION_URL=https://your-project.supabase.co/functions/v1

# Optional: AI Probe Mode (Dev-only feature for StoryContext tuning)
# Set to "true" to enable probe runner in Home AI Chat modal
# Default: false (disabled in production)
VITE_AI_PROBE_MODE=false

# Optional: Observability (error tracking + product analytics).
# Leave blank to disable entirely (the app no-ops, nothing loads or sends).
# Sentry DSN — https://sentry.io -> Project Settings -> Client Keys (DSN)
VITE_SENTRY_DSN=
# PostHog project API key — https://posthog.com -> Project Settings
VITE_POSTHOG_KEY=
# PostHog host (optional; defaults to US cloud)
VITE_POSTHOG_HOST=https://us.i.posthog.com
